{
    "expo": {
        "name": "Physique",
        "slug": "physique",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./assets/icon.png",
        "userInterfaceStyle": "dark",
        "newArchEnabled": true,
        "scheme": "physique",
        "splash": {
            "image": "./assets/splash-icon.png",
            "resizeMode": "contain",
            "backgroundColor": "#0A0A0F"
        },
        "ios": {
            "supportsTablet": true,
            "bundleIdentifier": "com.physique.app",
            "infoPlist": {
                "NSCameraUsageDescription": "Used to take body progress photos and scan food labels.",
                "NSPhotoLibraryUsageDescription": "Used to save and load body progress photos.",
                "NSLocationWhenInUseUsageDescription": "Used to record photo location for consistency tracking.",
                "NSMotionUsageDescription": "Used to detect device orientation for photo alignment."
            }
        },
        "android": {
            "adaptiveIcon": {
                "foregroundImage": "./assets/adaptive-icon.png",
                "backgroundColor": "#0A0A0F"
            },
            "package": "com.physique.app",
            "permissions": [
                "android.permission.CAMERA",
                "android.permission.RECORD_AUDIO",
                "android.permission.READ_EXTERNAL_STORAGE",
                "android.permission.WRITE_EXTERNAL_STORAGE",
                "android.permission.ACCESS_FINE_LOCATION",
                "android.permission.ACCESS_COARSE_LOCATION"
            ]
        },
        "web": {
            "bundler": "metro",
            "output": "static",
            "favicon": "./assets/favicon.png"
        },
        "plugins": [
            "expo-router",
            "expo-camera",
            [
                "expo-location",
                {
                    "locationAlwaysAndWhenInUsePermission": "Allow Physique to use your location for photo consistency tracking."
                }
            ],
            [
                "expo-notifications",
                {
                    "icon": "./assets/notification-icon.png",
                    "color": "#0A0A0F"
                }
            ]
        ],
        "experiments": {
            "typedRoutes": true
        }
    }
}